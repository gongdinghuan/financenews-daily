---
layout: base.njk
title: Cryptocurrency News
description: Latest crypto news, Bitcoin updates and blockchain developments
category: crypto
---

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Crypto News - {{ site.name }}",
  "description": "{{ description }}"
}
</script>

<h1>Cryptocurrency News</h1>
<p>Bitcoin, Ethereum and altcoin updates</p>

<div class="ad-slot top-banner">Advertisement</div>

<div class="news-grid">
  {% for item in news | filterBy('category', 'crypto') %}
  <article class="news-card">
    <div class="news-card-content">
      <span class="category-badge crypto">crypto</span>
      <div class="news-card-meta">{{ item.source }} | {{ item.pubDate | date }}</div>
      <h2><a href="/news/{{ item.slug }}/">{{ item.title }}</a></h2>
      <p>{{ item.summary | truncate(150) }}</p>
      <a href="/news/{{ item.slug }}/">Read more →</a>
    </div>
  </article>
  {% endfor %}
</div>
